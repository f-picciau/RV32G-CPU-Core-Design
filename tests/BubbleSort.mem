00000093 // 0x00: addi x1, x0, 0      (RAM base address = 0)
00400513 // 0x04: addi x10, x0, 4     
00a0a023 // 0x08: sw x10, 0(x1)       (RAM[0] = 4)
00300513 // 0x0c: addi x10, x0, 3     
00a0a223 // 0x10: sw x10, 4(x1)       (RAM[4] = 3)
00200513 // 0x14: addi x10, x0, 2     
00a0a423 // 0x18: sw x10, 8(x1)       (RAM[8] = 2)
00100513 // 0x1c: addi x10, x0, 1     
00a0a623 // 0x20: sw x10, 12(x1)      (RAM[12] = 1)
00400113 // 0x24: addi x2, x0, 4      (x2 = N = 4)
00000193 // 0x28: addi x3, x0, 0      (x3 = i = 0)
fff10393 // 0x2c: addi x7, x2, -1     (x7 = limit = 3)
00000213 // 0x30: addi x4, x0, 0      (x4 = j = 0)
00221413 // 0x34: slli x8, x4, 2      (Offset = j * 4)
00140433 // 0x38: add x8, x8, x1      (Actual RAM address)
00042283 // 0x3c: lw x5, 0(x8)        (Load A[j])
00442303 // 0x40: lw x6, 4(x8)        (Load A[j+1])
0062c663 // 0x44: blt x5, x6, 12      (if A[j] < A[j+1] skip swap)
00642023 // 0x48: sw x6, 0(x8)        (SWAP Part 1)
00542223 // 0x4c: sw x5, 4(x8)        (SWAP Part 2)
00120213 // 0x50: addi x4, x4, 1      (j++)
fe7240e3 // 0x54: blt x4, x7, -32     (Internal Loop  -> back to 0x34)
00118193 // 0x58: addi x3, x3, 1      (i++)
fc71c8e3 // 0x5c: blt x3, x7, -48     (External Loop  -> back to 0x2c)
