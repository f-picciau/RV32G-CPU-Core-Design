@00000000
00000093 // addi x1, x0, 0       (x1 = 0)     
00100113 // addi x2, x0, 1       (x2 = 0x1)
01011113 // slli x2, x2, 16      (x2 = 0x00010000)
fff00193 // addi x3, x0, -1      (x3 = 0xFFFFFFFF)
0101d193 // srli x3, x3, 16      (x3 = 0x0000FFFF)
00316233 // or   x4, x2, x3      (x4 = 0x0001FFFF)
0040a023 // sw   x4, 0(x1)       (Mem[0]=0x0001FFFF) 
0000d383 // lhu  x7, 0(x1)       (x5 = 0x0000FFFF)      
00209303 // lh   x6, 2(x1)       (x6 = 1)   